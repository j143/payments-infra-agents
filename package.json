{
  "name": "payments-infra-agents",
  "version": "0.1.0",
  "description": "Pragmatic payment infrastructure for Asia — Phase 1: The Plumbing",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx src/worker.ts",
