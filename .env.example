# Database
DATABASE_URL=postgres://user:password@localhost:5432/payments_infra

# API
API_PORT=3000
API_HOST=localhost

# Feature flags
HUMAN_APPROVAL_THRESHOLD=50000  # cents ($500)
CIRCUIT_BREAKER_WINDOW_MINUTES=10
JOB_POLL_INTERVAL_MS=5000
